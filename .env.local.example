# Copy this file to .env.local and fill in the values from your Supabase project.
# See SUPABASE_SETUP.md for where to find each key.

# Supabase project URL — looks like https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key — safe to ship to the browser. Starts with sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — SERVER-ONLY. Never commit. Bypasses RLS — treat like a root key.
# Starts with sb_secret_...
SUPABASE_SECRET_KEY=

# Public URL where the app is hosted. Used for QR codes + share links.
# Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public hostname (no protocol). Used for cookie scoping / og:url.
NEXT_PUBLIC_APP_HOSTNAME=localhost
